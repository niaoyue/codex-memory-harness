{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local://codex-memory-harness/schemas/subagent_dispatch_plan.schema.json",
  "title": "SubAgent Dispatch Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "task_id",
    "status",
    "execution_model",
    "autostart",
    "host_spawn_requests",
    "items",
    "completion_gate"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "task_id": {
      "type": "string"
    },
    "route_plan_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "execution_model": {
      "type": "string",
      "enum": [
        "host_subagent_or_manual"
      ]
    },
    "autostart": {
      "type": "boolean",
      "const": false
    },
    "host_spawn_requests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/host_spawn_request"
      }
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dispatch_item"
      }
    },
    "completion_gate": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "host_spawn_request": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "dispatch_id",
        "role",
        "agent_type",
        "message",
        "total_timeout_policy",
        "observation_window_policy",
        "no_fixed_total_timeout"
      ],
      "properties": {
        "dispatch_id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "review_commit_ref": {
          "type": "string"
        },
        "wait_policy": {
          "type": "string",
          "enum": [
            "progress_output_observation"
          ]
        },
        "idle_policy": {
          "type": "string",
          "enum": [
            "stdout_stderr_no_progress_only",
            "progress_signal_observation_only"
          ]
        },
        "total_timeout_policy": {
          "type": "string",
          "enum": [
            "none"
          ]
        },
        "observation_window_policy": {
          "type": "string",
          "enum": [
            "poll_only_never_interrupt"
          ]
        },
        "no_fixed_total_timeout": {
          "type": "boolean",
          "const": true
        },
        "recoverable_failure_policy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "recoverable_failure_types",
            "failure_rules",
            "primary_action",
            "primary_preconditions",
            "resume_message",
            "restart_action",
            "restart_only_when",
            "pass_condition"
          ],
          "properties": {
            "recoverable_failure_types": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "model_capacity",
                  "http_429",
                  "http_5xx",
                  "timeout"
                ]
              }
            },
            "failure_rules": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "failure_type",
                  "backoff_seconds",
                  "max_resume_attempts"
                ],
                "properties": {
                  "failure_type": {
                    "type": "string",
                    "enum": [
                      "model_capacity",
                      "http_429",
                      "http_5xx",
                      "timeout"
                    ]
                  },
                  "backoff_seconds": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "max_resume_attempts": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "minimum": 0
                  },
                  "attempt_policy": {
                    "type": "string",
                    "enum": [
                      "while_session_active",
                      "single_retry"
                    ]
                  }
                }
              }
            },
            "primary_action": {
              "type": "string",
              "enum": [
                "send_input_to_active_review_runner"
              ]
            },
            "primary_preconditions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "host_has_active_runner_session_handle",
                  "runner_session_not_completed_failed_or_closed",
                  "review_commit_ref_unchanged_since_runner_start",
                  "reviewed_commit_unchanged_since_runner_start"
                ]
              }
            },
            "resume_message": {
              "type": "string"
            },
            "restart_action": {
              "type": "string",
              "enum": [
                "restart_same_review_gate_command"
              ]
            },
            "restart_only_when": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "runner_session_closed_missing_or_unrecoverable",
                  "host_cannot_send_input_to_runner_session",
                  "review_commit_ref_changed_during_review",
                  "reviewed_commit_changed_during_review"
                ]
              }
            },
            "pass_condition": {
              "type": "string",
              "enum": [
                "review_gate_must_complete_cleanly"
              ]
            }
          }
        }
      }
    },
    "dispatch_item": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "dispatch_id",
        "role",
        "status",
        "prompt"
      ],
      "properties": {
        "dispatch_id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        }
      }
    }
  }
}
