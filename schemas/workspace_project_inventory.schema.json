{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local://codex-memory-harness/schemas/workspace_project_inventory.schema.json",
  "title": "Workspace Project Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "workspace",
    "projects"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "detected_at": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "scanner",
            "explicit_config",
            "merged"
          ]
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflict"
      }
    },
    "config_path": {
      "type": "string"
    },
    "config_loaded": {
      "type": "boolean"
    }
  },
  "$defs": {
    "domain": {
      "type": "string",
      "enum": [
        "game_client",
        "game_server",
        "backoffice_service",
        "backoffice_web",
        "design_docs",
        "art_pipeline",
        "build_release",
        "shared_library",
        "workspace_meta",
        "unknown"
      ]
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "cwd",
        "domain",
        "confidence",
        "signals"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"
        },
        "path": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "domain": {
          "$ref": "#/$defs/domain"
        },
        "engine": {
          "type": "string",
          "enum": [
            "unity",
            "laya",
            "cocos",
            "custom",
            "unknown"
          ]
        },
        "language": {
          "type": "string"
        },
        "framework": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "type": "string",
          "enum": [
            "scanner",
            "explicit_config"
          ]
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification_profiles": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "memory_binding": {
          "$ref": "#/$defs/memory_binding"
        },
        "config_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "conflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "message"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "project_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "message": {
          "type": "string"
        }
      }
    },
    "memory_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_scope",
        "semantic_scope"
      ],
      "properties": {
        "storage_scope": {
          "type": "string",
          "enum": [
            "project",
            "global",
            "auto"
          ]
        },
        "semantic_scope": {
          "type": "string",
          "enum": [
            "workspace",
            "project",
            "module",
            "workflow"
          ]
        },
        "project_id": {
          "type": "string"
        },
        "shared_memory_allowed": {
          "type": "boolean"
        }
      }
    }
  }
}
