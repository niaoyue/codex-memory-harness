{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local://codex-memory-harness/schemas/shared_memory.schema.json",
  "title": "Codex Shared Memory Entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "scope",
    "status",
    "confidence",
    "source",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$"
    },
    "scope": {
      "type": "string",
      "enum": [
        "workspace",
        "project",
        "module",
        "workflow"
      ]
    },
    "project_id": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "deprecated"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "source": {
      "type": "string"
    },
    "supersedes": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
