{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local://codex-memory-harness/schemas/verification_aggregation.schema.json",
  "title": "Workspace Verification Aggregation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "task_id",
    "overall_status",
    "verification_plan",
    "results"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "task_id": {
      "type": "string"
    },
    "route_plan_id": {
      "type": "string"
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "blocked",
        "gap",
        "not_run"
      ]
    },
    "verification_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verification_target"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verification_result"
      }
    },
    "release_gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "diagnostic_logging_disabled": {
          "$ref": "#/$defs/gate_result"
        },
        "sensitive_scan_passed": {
          "$ref": "#/$defs/gate_result"
        },
        "scope_guard_passed": {
          "$ref": "#/$defs/gate_result"
        },
        "debug_macro_disabled": {
          "$ref": "#/$defs/gate_result"
        },
        "localization_complete": {
          "$ref": "#/$defs/gate_result"
        },
        "platform_matrix_passed": {
          "$ref": "#/$defs/gate_result"
        },
        "webgl_minigame_compatible": {
          "$ref": "#/$defs/gate_result"
        },
        "asset_bundle_dependency_policy": {
          "$ref": "#/$defs/gate_result"
        },
        "package_budget": {
          "$ref": "#/$defs/gate_result"
        },
        "performance_budget": {
          "$ref": "#/$defs/gate_result"
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verification_gap"
      }
    }
  },
  "$defs": {
    "verification_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "cwd",
        "verification_profile_ids",
        "blocking"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "verification_cwd": {
          "type": "string"
        },
        "verification_profile_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "verification_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "profile_id",
        "cwd",
        "status",
        "blocking"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "profile_id": {
          "type": "string"
        },
        "command_id": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped",
            "blocked",
            "manual_required"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "command": {
          "type": "string"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "stdout_excerpt": {
          "type": "string"
        },
        "stderr_excerpt": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "artifact_path": {
          "type": "string"
        },
        "skip_reason": {
          "type": "string"
        }
      }
    },
    "gate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "blocking"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "skipped",
            "manual_required"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        },
        "scanned_files": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {
          "type": "boolean"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gate_finding"
          }
        }
      }
    },
    "gate_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "type": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "verification_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "reason",
        "blocking"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "profile_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "blocking": {
          "type": "boolean"
        }
      }
    }
  }
}
