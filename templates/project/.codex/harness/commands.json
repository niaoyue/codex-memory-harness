{
  "version": 1,
  "settings": {
    "default_timeout_seconds": 120,
    "max_output_chars": 1200
  },
  "commands": {
    "memory_check": {
      "description": "校验全局 codex-memory 插件入口与 marketplace 接入。",
      "command": "codex memory check-install",
      "argv": [
        "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "C:\\Users\\<USER>\\plugins\\codex-memory\\scripts\\codexm.ps1",
        "memory",
        "check-install"
      ],
      "timeout_seconds": 60,
      "touched_paths": [
        "C:/Users/<USER>/plugins/codex-memory",
        "C:/Users/<USER>/.agents/plugins/marketplace.json"
      ]
    },
    "bootstrap_doctor": {
      "description": "校验当前项目的 bootstrap、memory 与 harness 接入状态。",
      "command": "codex memory doctor",
      "argv": [
        "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "C:\\Users\\<USER>\\plugins\\codex-memory\\scripts\\codexm.ps1",
        "memory",
        "doctor"
      ],
      "timeout_seconds": 60,
      "touched_paths": [
        ".codex/harness/commands.json",
        ".codex/harness/project_profile.json",
        ".codex/memories"
      ]
    }
  }
}
