{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh ./scripts/hook_launcher.sh --codex-event UserPromptSubmit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh ./scripts/hook_launcher.sh --codex-event PostToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh ./scripts/hook_launcher.sh --codex-event Stop"
          }
        ]
      }
    ]
  }
}
