{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /c .\\scripts\\hook_launcher.cmd --codex-event UserPromptSubmit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /c .\\scripts\\hook_launcher.cmd --codex-event PostToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cmd /d /c .\\scripts\\hook_launcher.cmd --codex-event Stop"
          }
        ]
      }
    ]
  }
}
